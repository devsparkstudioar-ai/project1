# Copy this file to ".env" and fill in your real values. Never commit ".env".

# PostgreSQL connection string.
# Local example:        postgres://postgres:yourpassword@localhost:5432/metro_courier
# Managed DB (Render/Neon/Supabase) will give you a full string like:
# postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://postgres:Roosee1147@localhost:5432/metro_courier

# Port the API server listens on
PORT=4000

# Comma-separated list of origins allowed to call this API.
# Add your Vercel/production domain here once you deploy the frontend.
CORS_ORIGIN=http://localhost:5173

# Max upload size for the file-storage endpoint (in MB)
MAX_UPLOAD_MB=15
